rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidPost(data) {
      return data.keys().hasAll(['title', 'author', 'type', 'createdAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.author is string && data.author.size() <= 100 &&
             data.type in ['article', 'podcast', 'video', 'discussion'] &&
             (data.has('excerpt') ? data.excerpt is string && data.excerpt.size() <= 1000 : true) &&
             (data.has('content') ? data.content is string && data.content.size() <= 65536 : true) &&
             (data.has('image') ? data.image is string && data.image.size() <= 500 : true) &&
             (data.has('tags') ? data.tags is list && data.tags.size() <= 10 : true);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.email.size() <= 256 &&
             (data.has('displayName') ? data.displayName is string && data.displayName.size() <= 100 : true);
    }

    // --- Collection Rules ---

    // Unified Posts Collection
    match /posts/{postId} {
      allow get: if true; // Publicly readable individual posts
      allow list: if true; // Publicly listable posts (ideal for blog lists)
      
      allow create: if isEmailVerified() && 
                      isValidId(postId) && 
                      isValidPost(incoming()) &&
                      incoming().authorId == request.auth.uid &&
                      incoming().createdAt == request.time;
      
      allow update: if isEmailVerified() && 
                      isValidPost(incoming()) &&
                      isOwner(existing().authorId) &&
                      incoming().authorId == existing().authorId && // Author immutable
                      incoming().createdAt == existing().createdAt && // CreatedAt immutable
                      incoming().updatedAt == request.time &&
                      // Limit what can be updated
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'excerpt', 'content', 'image', 'tags', 'hasAudio', 'hasVideo', 'updatedAt', 'likes', 'comments']);
      
      allow delete: if isEmailVerified() && isOwner(existing().authorId);
    }

    // User Profiles
    match /users/{uid} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && isAdmin(); // Only admins can list users if implemented
      
      allow create: if isEmailVerified() && 
                      isValidId(uid) && 
                      isOwner(uid) && 
                      isValidUser(incoming()) &&
                      incoming().createdAt == request.time;
      
      allow update: if isEmailVerified() && 
                      isOwner(uid) && 
                      isValidUser(incoming()) &&
                      incoming().uid == existing().uid &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'role']);
    }

    // Admin helper (placeholder if ever needed)
    function isAdmin() {
      // In a real app, you'd lookup an admins collection
      // example: return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      return false; 
    }
  }
}
